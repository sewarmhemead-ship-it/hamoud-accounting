# ── التخزين المحلي (الوضع الافتراضي) ──
# قاعدة SQLite على القرص — لا تُرفع إلى Git (انظر .gitignore)
NODE_ENV=development
PORT=3001
DB_PATH=./data/hamoud.db
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
# ADMIN_PASSWORD=admin123

# ── تشغيل محلي «إنتاج» (خدمة واحدة على المنفذ 3001) ──
# NODE_ENV=production
# JWT_SECRET=<مفتاح عشوائي طويل — إلزامي في production>
# شغّل من جذر المشروع: start-prod.bat
# أو: cd backend && npm run build:ui && node server.js

# ── اختياري: نشر سحابي (Railway + Volume) ──
# DB_PATH=/data/hamoud.db
