# ── التطوير المحلي ──
NODE_ENV=development
PORT=3001
DB_PATH=./data/hamoud.db
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── الإنتاج (Railway) ──
# NODE_ENV=production
# PORT يضبطه Railway تلقائياً — لا تضبطه يدوياً
# ضع قاعدة البيانات داخل الـVolume كي لا تُمحى مع كل نشر:
# DB_PATH=/data/hamoud.db
# JWT_SECRET=<مفتاح عشوائي طويل — إلزامي في الإنتاج وإلا يتوقف الإقلاع>
# ADMIN_PASSWORD=<كلمة مرور المدير الأولى — اختياري؛ الافتراضي admin123>
